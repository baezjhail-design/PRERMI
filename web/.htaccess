# Seguridad y rutas canónicas para frontend web de PRERMI
Options -Indexes

RewriteEngine On

# Canonicalizar rutas legacy HTML de autenticación
RewriteRule ^login\.html$ login.php [R=301,L,NC]
RewriteRule ^register\.html$ register.php [R=301,L,NC]

# Evitar exposición de respaldos y archivos temporales
<FilesMatch "\.(bak|old|orig|save|swp|tmp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
</FilesMatch>

# Encabezados útiles para páginas sensibles de acceso
<FilesMatch "^(login|register|loginA|registerA)\.(php|html)$">
    <IfModule mod_headers.c>
        Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header always set Pragma "no-cache"
        Header always set Expires "0"
        Header always set X-Robots-Tag "noindex, nofollow, noarchive"
    </IfModule>
</FilesMatch>
